{
  "name": "desktop",
  "version": "1.0.",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev:electron": "electron .",
    "dev": "npm run dev:electron",
    "build": "electron-builder --win nsis",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.wabts26.desktop",
    "productName": "WA-BTS26",
    "npmRebuild": false,
    "directories": {
      "buildResources": "assets"
    },
    "extraResources": [
      {
        "from": "../frontend",
        "to": "frontend",
        "filter": [
          "**/*",
          "!node_modules{,/**}",
          "!package-lock.json",
          "!package.json"
        ]
      },
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!__pycache__{,/**}",
          "!storage{,/**}",
          "!database.db"
        ]
      },
      {
        "from": "../wa-gateway",
        "to": "wa-gateway",
        "filter": [
          "index.js",
          "websocket.js",
          "whatsapp.js",
          "package.json",
          "!session{,/**}",
          "!package-lock.json"
        ]
      },
      {
        "from": "../wa-gateway/node_modules",
        "to": "wa-gateway/node_modules",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "WA-BTS26",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true, 
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "wait-on": "^9.0.4"
  }
}

